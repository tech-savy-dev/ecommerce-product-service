{
  "name": "ecommerce-product-service",
  "build": {
    "dockerfile": "../.gitpod.Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "remoteUser": "gitpod",
  "containerUser": "gitpod",
  "workspaceFolder": "/workspace/ecommerce-product-service",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/ecommerce-product-service,type=bind",
  "forwardPorts": [
    8080
  ],
  "portsAttributes": {
    "8080": {
      "label": "Port 8080",
      "onAutoForward": "openPreview",
      "elevateIfNeeded": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "Pivotal.vscode-spring-boot",
        "redhat.vscode-xml",
        "eamodio.gitlens",
        "github.copilot"
      ]
    }
  }
}